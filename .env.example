# ---------------------------------------------------------------------------
# Polymarket copy-trading bot — secrets & live-trading credentials
# Copy to `.env` and fill in. Only required when MODE=live.
# DRY_RUN mode (the default) needs NONE of these.
# ---------------------------------------------------------------------------

# Log verbosity: error | warn | info | debug | trace
RUST_LOG=info

# --- CLOB credentials (live mode only) ---------------------------------------
# The EOA private key that signs orders (0x-prefixed, 64 hex chars).
# NEVER commit this. Keep it only in .env (gitignored).
PM_PRIVATE_KEY=

# Polymarket CLOB API credentials (derive once via py-clob-client `create_api_key`,
# or from the Polymarket UI). Required for L2-authenticated order placement.
PM_API_KEY=
PM_API_SECRET=
PM_API_PASSPHRASE=

# The address that actually HOLDS your funds (the "maker").
# - signature_type 0 (EOA):        leave blank -> defaults to the key's address
# - signature_type 1 (Email/Magic, POLY_PROXY)
# - signature_type 2 (Browser wallet, POLY_GNOSIS_SAFE)
# For proxy/safe types, set this to your Polymarket deposit (proxy) address.
PM_FUNDER_ADDRESS=

# 0 = EOA, 1 = POLY_PROXY (email/magic login), 2 = POLY_GNOSIS_SAFE (browser wallet)
PM_SIGNATURE_TYPE=0
