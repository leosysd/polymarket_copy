# ---------------------------------------------------------------------------
# Polymarket copy-trading bot — secrets & live-trading credentials
# Copy to `.env` and fill in. Only required when MODE=live.
# DRY_RUN mode (the default) needs NONE of these.
# ---------------------------------------------------------------------------

# Log verbosity: error | warn | info | debug | trace
RUST_LOG=info

# --- REQUIRED: Polygon WebSocket RPC --------------------------------------
# The monitor subscribes to on-chain OrderFilled events over this connection.
# Must be a wss:// endpoint (plain https RPC cannot do subscriptions).
# Free options: Alchemy / Infura / QuickNode. Example (Alchemy):
#   wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
PM_WSS_RPC=

# --- CLOB credentials (live mode only) ---------------------------------------
# The EOA private key that signs orders (0x-prefixed, 64 hex chars).
# NEVER commit this. Keep it only in .env (gitignored).
PM_PRIVATE_KEY=

# Polymarket CLOB API credentials, used for L2-authenticated order placement.
# OPTIONAL: if left blank, the bot derives them automatically from PM_PRIVATE_KEY
# on startup. You can also print them yourself with `pmcopy derive-key`.
PM_API_KEY=
PM_API_SECRET=
PM_API_PASSPHRASE=

# Your Polymarket DEPOSIT wallet = the 0x... address on your Polymarket profile
# page (where your balance/positions live). Required for signature_type 1/2/3.
PM_FUNDER_ADDRESS=

# 0 = EOA (fund the key's address directly)
# 1 = POLY_PROXY  (older email/Magic)
# 2 = POLY_GNOSIS_SAFE  (older browser wallet)
# 3 = POLY_1271  (current Polymarket "deposit wallet" flow — use this for
#                 email/browser accounts on the new CLOB; funder = profile addr)
PM_SIGNATURE_TYPE=3
